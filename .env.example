# ─────────────────────────────────────────────────────────────────────────────
#  WellNest V2  —  Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit your actual .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development       # Change to "production" when deploying

# ── API Base URL ──────────────────────────────────────────────────────────────
# This value is served to the browser via GET /config and used by every
# frontend fetch() call.  The frontend never has any URL hardcoded.
#
# LOCAL: leave blank  →  frontend uses relative URLs (works because Express
#                        serves both the API and the HTML from the same port)
# PRODUCTION (split hosting): set to your backend's full URL
#   e.g.  API_BASE_URL=https://wellnest-backend.onrender.com
API_BASE_URL=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Option A — Local MongoDB (default for development)
MONGO_URI=mongodb://127.0.0.1:27017/wellnest

# Option B — MongoDB Atlas (production / cloud)
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/wellnest?retryWrites=true&w=majority

# ── CORS ──────────────────────────────────────────────────────────────────────
# Leave blank while running locally (localhost is always whitelisted).
# Set to your production frontend URL when frontend and backend are on different domains.
CORS_ORIGIN=https://wellnestadl.netlify.app

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_SECRET=your_admin_secret_key_here

# ── EmailJS ───────────────────────────────────────────────────────────────────
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_BOOKING_TEMPLATE_ID=template_yyyyyyy
EMAILJS_PUBLIC_KEY=public_key_xxxxxxx

# ── Jitsi Meet ────────────────────────────────────────────────────────────────
JITSI_DOMAIN=meet.jit.si