# Server configuration
PORT=3000
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/wellnest?retryWrites=true&w=majority

# CORS settings (Frontend deployed URL, e.g. Netlify)
CORS_ORIGIN=https://wellnestadl.netlify.app

# Admin Secret credentials
ADMIN_SECRET=your_admin_secret_key_here

# EmailJS credentials
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_BOOKING_TEMPLATE_ID=template_yyyyyyy
EMAILJS_PUBLIC_KEY=public_key_xxxxxxx

# Jitsi consultation room domain
JITSI_DOMAIN=meet.jit.si